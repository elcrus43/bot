# Bot Token (получить в @BotFather)
BOT_TOKEN=your_bot_token_here

# Supabase (получить в настройках проекта https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# SiliconFlow API (получить на https://cloud.siliconflow.cn)
SILICONFLOW_API_KEY=your-siliconflow-api-key

# Telegram ID риэлтора (узнать в @userinfobot)
REALTOR_TELEGRAM_ID=123456789

# Telegram ID админов (через запятую, узнать в @userinfobot)
ADMIN_IDS=123456789,987654321

# Максимальное количество сообщений истории для AI контекста
MAX_HISTORY_MESSAGES=20
